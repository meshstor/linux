#!/usr/bin/env bash
# rebuild-main — reconstruct a meshstor-main-equivalent tree from a fresh
# torvalds/linux clone, slim it via git filter-repo, then apply the
# meshstor-harness branch and zero or more feature branches as patches.
#
# Branches are sourced local-first: a branch that exists as a local head in
# this repo (even un-pushed) is used as-is; otherwise it is fetched from the
# meshstor remote. An all-local run needs no access to the remote.
#
# See docs/superpowers/specs/2026-05-04-rebuild-main-script-design.md
#
# Usage: bin/rebuild-main [options] [feature ...]
set -euo pipefail

UPSTREAM_URL="https://github.com/torvalds/linux.git"
UPSTREAM_BRANCH="master"
# MESHSTOR_URL can be overridden via env for read-only/CI use
# (e.g., MESHSTOR_URL=https://github.com/meshstor/linux.git when no SSH agent).
MESHSTOR_URL="${MESHSTOR_URL:-https://github.com/meshstor/linux}"
HARNESS_BRANCH="meshstor-harness"
FILTER_PATHS=(drivers/md tools/testing/selftests/md)
REPO_ROOT="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
CACHE_DIR="${MESHSTOR_UPSTREAM_MIRROR_DIR:-$REPO_ROOT/build}"
MIRROR="$CACHE_DIR/torvalds-linux.git"
DEFAULT_OUTPUT="$REPO_ROOT/build/linux-meshstor-rebuilt"

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] [feature ...]

Reconstruct a meshstor-main-equivalent tree from upstream + harness +
the listed feature branches (applied as patches in the given order).

By default produces a kernel-tree-only output (filtered upstream + features);
pass --with-harness to also bake in $HARNESS_BRANCH (selftests, dkms scripts,
docs, bin helpers). Packaging (bin/build-rpm etc.) reads drivers/md/ from
this output by default — run from this repo regardless of --with-harness.

Branches are sourced from this repo's local heads first (so un-pushed local
work builds as-is), falling back to the meshstor remote ($MESHSTOR_URL).

Options:
  -o, --output DIR     Output directory (default: $DEFAULT_OUTPUT)
  --no-fetch           Skip refreshing the cached upstream mirror
  --with-harness       Also apply $HARNESS_BRANCH on top of filtered upstream
                       before features (default: kernel tree only)
  --keep               Bail (instead of wiping) if OUTPUT_DIR already exists
  -h, --help           Show this help

Examples:
  $(basename "$0")
      -> filtered upstream only
  $(basename "$0") md-latency-ewma
      -> filtered upstream + latency-ewma
  $(basename "$0") per-bucket-arrays md-latency-ewma
      -> filtered upstream + three features in given order
  $(basename "$0") --with-harness md-latency-ewma
      -> filtered upstream + harness + latency-ewma
EOF
}

OUTPUT_DIR="$DEFAULT_OUTPUT"
NO_FETCH=
WITH_HARNESS=
KEEP=
FEATURES=()

while (($#)); do
    case "$1" in
        -o|--output)    OUTPUT_DIR="$2"; shift 2 ;;
        --no-fetch)     NO_FETCH=1; shift ;;
        --with-harness) WITH_HARNESS=1; shift ;;
        --keep)         KEEP=1; shift ;;
        -h|--help)      usage; exit 0 ;;
        --)             shift; FEATURES+=("$@"); break ;;
        -*)             echo "error: unknown option: $1" >&2; usage >&2; exit 2 ;;
        *)              FEATURES+=("$1"); shift ;;
    esac
done

# Resolve OUTPUT_DIR to an absolute path (parent must exist).
OUTPUT_DIR="$(realpath -m "$OUTPUT_DIR")"

require_git_version() {
    local have major minor
    have="$(git --version 2>/dev/null | awk '{print $3}')" \
        || { echo "error: git is not installed" >&2; exit 1; }
    IFS=. read -r major minor _ <<<"$have"
    if (( major < 2 || (major == 2 && minor < 30) )); then
        echo "error: git >= 2.30 required (found: $have)" >&2
        exit 1
    fi
}

require_filter_repo() {
    if ! git filter-repo --version >/dev/null 2>&1; then
        echo "error: git-filter-repo not installed; see https://github.com/newren/git-filter-repo" >&2
        exit 1
    fi
}

require_remote_reachable() {
    if ! git ls-remote "$MESHSTOR_URL" >/dev/null 2>&1; then
        echo "error: cannot reach $MESHSTOR_URL — check SSH key / network" >&2
        exit 1
    fi
}

# A branch present as a local head in this repo (even un-pushed) wins;
# otherwise it must exist on the meshstor remote.
branch_is_local() {
    git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$1"
}

REMOTE_CHECKED=
require_branch_available() {
    local branch="$1" label="$2"
    branch_is_local "$branch" && return 0
    if [[ -z "$REMOTE_CHECKED" ]]; then
        require_remote_reachable
        REMOTE_CHECKED=1
    fi
    if ! git ls-remote --exit-code "$MESHSTOR_URL" "refs/heads/$branch" >/dev/null 2>&1; then
        if [[ "$label" == harness ]]; then
            echo "error: branch '$branch' not found locally in $REPO_ROOT or on $MESHSTOR_URL — bootstrap it first" >&2
            echo "       (see docs/superpowers/specs/2026-05-04-rebuild-main-script-design.md, Bootstrap section)" >&2
        else
            echo "error: feature branch '$branch' not found locally in $REPO_ROOT or on $MESHSTOR_URL" >&2
        fi
        exit 1
    fi
}

require_git_version
require_filter_repo

prepare_output_dir() {
    # Refuse obviously dangerous paths
    case "$OUTPUT_DIR" in
        /|"$HOME"|"$REPO_ROOT")
            echo "error: refusing to use OUTPUT_DIR=$OUTPUT_DIR" >&2
            exit 1
            ;;
    esac

    if [[ -e "$OUTPUT_DIR" ]]; then
        if [[ -n "$KEEP" ]]; then
            echo "error: $OUTPUT_DIR exists; remove it or run without --keep" >&2
            exit 1
        fi
        # Only wipe if it's a previous rebuild-main output (sentinel present),
        # OR not a git repo at all (we'd never put one there ourselves, refuse).
        if [[ -d "$OUTPUT_DIR/.git" && -f "$OUTPUT_DIR/.meshstor-rebuilt" ]]; then
            echo "rebuild-main: wiping previous output at $OUTPUT_DIR"
            rm -rf "$OUTPUT_DIR"
        else
            echo "error: $OUTPUT_DIR exists but is not a previous rebuild-main output" >&2
            echo "       (no .meshstor-rebuilt sentinel). Refusing to wipe; remove manually." >&2
            exit 1
        fi
    fi

    mkdir -p "$(dirname "$OUTPUT_DIR")"
    mkdir -p "$CACHE_DIR"
}

prepare_output_dir

[[ -n "$WITH_HARNESS" ]] && require_branch_available "$HARNESS_BRANCH" harness
for f in "${FEATURES[@]}"; do
    require_branch_available "$f" feature
done

stage1_refresh_upstream() {
    if [[ ! -d "$MIRROR" ]]; then
        # Full bare clone (no --filter=blob:none): filter-repo needs every blob
        # in the filtered paths and a partial clone fails it with
        # "fatal: Blob not found". Cost: ~5GB on disk, one-time.
        echo "rebuild-main: cloning $UPSTREAM_URL into $MIRROR (first run; ~5GB, one-time)"
        git clone --bare "$UPSTREAM_URL" "$MIRROR"
    elif [[ -z "$NO_FETCH" ]]; then
        echo "rebuild-main: refreshing cached upstream mirror"
        git -C "$MIRROR" fetch origin "$UPSTREAM_BRANCH:$UPSTREAM_BRANCH"
    else
        echo "rebuild-main: --no-fetch — skipping mirror refresh"
    fi
    UPSTREAM_SHA="$(git -C "$MIRROR" rev-parse "$UPSTREAM_BRANCH")"
    echo "rebuild-main: upstream $UPSTREAM_BRANCH = $UPSTREAM_SHA"
}

stage1_refresh_upstream

stage2_filter_repo() {
    echo "rebuild-main: local clone -> $OUTPUT_DIR"
    git clone "$MIRROR" "$OUTPUT_DIR"
    cd "$OUTPUT_DIR"
    # `git am` needs a committer identity. The clone inherits none, and CI/perf
    # boxes often lack a global one (hostname like "*.(none)" breaks
    # auto-detection). Pin a synthetic local identity so rebuilds work on any
    # machine and `git log` clearly attributes the rewrite.
    git config user.name "rebuild-main"
    git config user.email "rebuild-main@meshstor.local"
    git checkout "$UPSTREAM_BRANCH"
    echo "rebuild-main: filter-repo (paths: ${FILTER_PATHS[*]})"
    local filter_args=()
    for p in "${FILTER_PATHS[@]}"; do filter_args+=(--path "$p"); done
    git filter-repo "${filter_args[@]}" --force
    FILTERED_SHA="$(git rev-parse HEAD)"
    echo "rebuild-main: filtered HEAD = $FILTERED_SHA"
}

stage2_filter_repo

# Idempotently add the meshstor remote to the output repo and fetch its
# master — the format-patch base for remote-sourced branches. State-checked
# rather than flag-guarded because callers run inside $(...) subshells.
# NB: the meshstor lineage does NOT share commit hashes with the torvalds
# mirror (the fork's history was rewritten at import — different root
# commits), so the mirror's master can never anchor a meshstor merge-base.
ensure_meshstor_remote() {
    git remote get-url meshstor >/dev/null 2>&1 \
        || git remote add meshstor "$MESHSTOR_URL"
    git rev-parse --verify --quiet "refs/remotes/meshstor/$UPSTREAM_BRANCH" >/dev/null \
        || git fetch meshstor "$UPSTREAM_BRANCH:refs/remotes/meshstor/$UPSTREAM_BRANCH" >&2
}

# Apply <branch> onto the current HEAD as a patch series. The branch is
# sourced local-first: this repo's local head wins (so un-pushed work builds
# as-is) and the series is format-patched straight out of this repo against
# its local master — no network. A branch absent locally is fetched from
# the meshstor remote alongside the remote's master, exactly the original
# remote-only flow. Returns the patch count via stdout (caller captures);
# all status messages go to stderr to avoid polluting the captured value.
# Leaves .git/rebase-apply/ if git am fails.
# $1 = branch name, $2 = stage label (used in error messages).
apply_branch_as_patches() {
    local branch="$1" label="$2"
    local safe_dir base count patch_dir cand mb
    safe_dir="$(echo "$branch" | tr / -)"
    patch_dir="$OUTPUT_DIR/.rebuild-patches/$safe_dir"
    mkdir -p "$patch_dir"
    if branch_is_local "$branch"; then
        echo "rebuild-main: sourcing $branch from local repo" >&2
        # Fork point against the local master head; origin/master is also
        # tried in case the branch was rebased onto a fetched-but-not-
        # fast-forwarded master — the newer (descendant) fork point wins.
        base=""
        for cand in "refs/heads/$UPSTREAM_BRANCH" "refs/remotes/origin/$UPSTREAM_BRANCH"; do
            git -C "$REPO_ROOT" rev-parse --verify --quiet "$cand" >/dev/null || continue
            mb="$(git -C "$REPO_ROOT" merge-base "refs/heads/$branch" "$cand")" || continue
            if [[ -z "$base" ]] || git -C "$REPO_ROOT" merge-base --is-ancestor "$base" "$mb"; then
                base="$mb"
            fi
        done
        if [[ -z "$base" ]]; then
            echo "error: no merge-base between '$branch' and $UPSTREAM_BRANCH in $REPO_ROOT" >&2
            exit 1
        fi
        git -C "$REPO_ROOT" format-patch "$base..refs/heads/$branch" -o "$patch_dir" >/dev/null
    else
        echo "rebuild-main: sourcing $branch from $MESHSTOR_URL" >&2
        ensure_meshstor_remote
        git fetch meshstor "$branch:refs/remotes/meshstor/$branch" >&2
        base="$(git merge-base "meshstor/$branch" "meshstor/$UPSTREAM_BRANCH")"
        git format-patch "$base..meshstor/$branch" -o "$patch_dir" >/dev/null
    fi
    count="$(find "$patch_dir" -name '*.patch' | wc -l | tr -d ' ')"
    if (( count == 0 )); then
        echo "rebuild-main: $label has no patches above $base — nothing to apply" >&2
        rm -rf "$patch_dir"
        echo "0"
        return 0
    fi
    echo "rebuild-main: applying $count patches from $branch ($label)" >&2
    if ! git am "$patch_dir"/*.patch >&2; then
        echo "" >&2
        echo "error: git am failed while applying $label ($branch)" >&2
        echo "       output dir: $OUTPUT_DIR" >&2
        echo "       resume with: cd $OUTPUT_DIR && git am --continue   (after resolving)" >&2
        echo "       or abort:    cd $OUTPUT_DIR && git am --abort" >&2
        exit 1
    fi
    rm -rf "$patch_dir"
    echo "$count"
}

stage3_apply_harness() {
    HARNESS_PATCH_COUNT="$(apply_branch_as_patches "$HARNESS_BRANCH" harness)"
    HARNESS_SHA="$(git rev-parse HEAD)"
    echo "rebuild-main: harness HEAD = $HARNESS_SHA"
}

if [[ -n "$WITH_HARNESS" ]]; then
    stage3_apply_harness
else
    HARNESS_PATCH_COUNT=0
    HARNESS_SHA="(skipped; pass --with-harness to apply)"
    echo "rebuild-main: skipping $HARNESS_BRANCH (pass --with-harness to apply)"
fi

stage4_apply_features() {
    APPLIED_FEATURES=()  # parallel arrays for the summary
    APPLIED_TAGS=()
    APPLIED_COUNTS=()
    for feature in "${FEATURES[@]}"; do
        local count tag
        count="$(apply_branch_as_patches "$feature" "feature:$feature")"
        tag="feat-$(echo "$feature" | tr / -)-applied"
        git tag "$tag"
        APPLIED_FEATURES+=("$feature")
        APPLIED_TAGS+=("$tag")
        APPLIED_COUNTS+=("$count")
        echo "rebuild-main: tagged $tag at $(git rev-parse --short HEAD)"
    done
}

stage4_apply_features

stage5_finalize() {
    git branch -m "$UPSTREAM_BRANCH" meshstor-main-rebuilt
    touch "$OUTPUT_DIR/.meshstor-rebuilt"
    local final_sha
    final_sha="$(git rev-parse HEAD)"
    cat <<EOF

==============================================================
rebuild-main: success
==============================================================
Output:        $OUTPUT_DIR
Branch:        meshstor-main-rebuilt
Upstream:      $UPSTREAM_SHA
Filtered:      $FILTERED_SHA
Harness:       $(if [[ -n "$WITH_HARNESS" ]]; then echo "$HARNESS_SHA ($HARNESS_PATCH_COUNT patches from $HARNESS_BRANCH)"; else echo "(skipped; pass --with-harness to apply)"; fi)
EOF
    if (( ${#APPLIED_FEATURES[@]} == 0 )); then
        echo "Features:      (none)"
    else
        echo "Features (in applied order):"
        for i in "${!APPLIED_FEATURES[@]}"; do
            printf "  %-50s -> %-50s (%s patches)\n" \
                "${APPLIED_FEATURES[$i]}" "${APPLIED_TAGS[$i]}" "${APPLIED_COUNTS[$i]}"
        done
    fi
    echo "Final HEAD:    $final_sha"
    echo "=============================================================="
}

stage5_finalize
