#!/usr/bin/env bash
# perf-bitmap-compare — orchestrate a 3-mode bitmap perf comparison
# (kernel-md-internal, ms-internal, ms-lockless) on the same code base.
#
# Spec: docs/superpowers/specs/2026-05-10-perf-bitmap-compare-design.md
# Plan: docs/superpowers/plans/2026-05-10-perf-bitmap-compare.md
#
# Usage: sudo bin/perf-bitmap-compare PART_LOCAL PART_REMOTE [SUITE...]
set -euo pipefail

REPO_ROOT="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
REBUILD_MAIN="$REPO_ROOT/bin/rebuild-main"
BUILD_TARBALL="$REPO_ROOT/bin/build-tarball"
RUN_PERF="$REPO_ROOT/bin/perf-bench-tcp"
EXTRACT_TABLE="$REPO_ROOT/bin/perf-extract-table"
REBUILT_TREE="${REBUILT_TREE:-$REPO_ROOT/build/linux-meshstor-rebuilt}"
MDADM_BIN="${MDADM_BIN:-/home/${SUDO_USER:-$USER}/mdadm/mdadm}"
MSADM_WRAPPER="$REPO_ROOT/build/msadm"
MESHSTOR_URL_FOR_REBUILD="${MESHSTOR_URL_FOR_REBUILD:-https://github.com/meshstor/linux.git}"

DATE_TAG="${DATE_TAG:-$(date -u +%s)}"
OUT_BASE="$REPO_ROOT/results/perf-bitmap-$DATE_TAG"

# Default suites — same set perf-compare uses.
SUITES_BASE="${SUITES_BASE:-/home/${SUDO_USER:-$USER}/csi-perf-test/suites}"
DEFAULT_SUITES=(
    snia-randread-iops snia-randwrite-iops
    snia-randread-lat  snia-randwrite-lat
    kp-asym-read kp-hot-region-write
    kp-hot-region-largeio-write kp-resync-overlap-write
)

# ---- mode tables ----
declare -A MODE_ENGINE=(
    [kernel-md-internal]=md
    [ms-internal]=ms
    [ms-lockless]=ms
)
declare -A MODE_BITMAP=(
    [kernel-md-internal]=internal
    [ms-internal]=internal
    [ms-lockless]=lockless
)
declare -A MODE_NEEDS_MS=(
    [kernel-md-internal]=0
    [ms-internal]=1
    [ms-lockless]=1
)
DEFAULT_MODE_ORDER=(kernel-md-internal ms-internal ms-lockless)

# ---- globals ----
LEVEL="raid1"
BRANCH=""
PORT="7720"
COOL_THRESH_K="${COOL_THRESH_K:-348}"
NO_CACHE=0
LOCALS=()
REMOTES=()
SELECTED_MODES=()
SUITES_POS=()
# Lib contract: SELECTED_VARIANTS/VARIANT_LABELS/VARIANT_ARGS/VARIANT_VER are
# read by resolve_shas/cache_key_for/obtain_tarball/restore_system in
# perf-compare-lib.sh.
# shellcheck disable=SC2034
SELECTED_VARIANTS=("meshstor")
# shellcheck disable=SC2034
VARIANT_LABELS=("meshstor")
# shellcheck disable=SC2034
declare -A VARIANT_ARGS=( [meshstor]="" )
declare -A VARIANT_VER=(  [meshstor]="0.1.0-bitmapcmp" )
# shellcheck disable=SC2034  # set by remove_existing_pkg, read by restore_system (both in lib)
SYSTEM_DKMS_VER=""

# Source the shared lib for log/warn/die, cooling, cache, dkms helpers.
# shellcheck source=perf-compare-lib.sh
source "$REPO_ROOT/bin/perf-compare-lib.sh"

# ---- pure helpers (testable) ----

parse_modes() {
    local raw="$1"
    if [[ -z "$raw" ]]; then
        SELECTED_MODES=("${DEFAULT_MODE_ORDER[@]}")
        return 0
    fi
    SELECTED_MODES=()
    local IFS=','
    local m
    for m in $raw; do
        if [[ -z "${MODE_ENGINE[$m]:-}" ]]; then
            echo "error: unknown mode '$m' (choices: ${!MODE_ENGINE[*]})" >&2
            return 1
        fi
        SELECTED_MODES+=("$m")
    done
    return 0
}

derive_variant_ver() {
    if [[ -n "${BRANCH:-}" ]]; then
        VARIANT_VER[meshstor]="0.1.0-bitmapcmp-${BRANCH}"
    else
        VARIANT_VER[meshstor]="0.1.0-bitmapcmp"
    fi
    # shellcheck disable=SC2034  # consumed by lib's resolve_shas/obtain_tarball
    VARIANT_ARGS[meshstor]="${BRANCH:-}"
}

usage() {
    cat <<EOF
Usage:
  sudo $(basename "$0") PART_LOCAL PART_REMOTE [SUITE...]
  sudo $(basename "$0") --level=raid10 --local=A --local=B \\
                        --remote=C --remote=D [SUITE...]

Compare bitmap performance across kernel-md-internal, ms-internal, and
ms-lockless on the same code base. Builds and installs meshstor-ms
once (or merges \$BRANCH atop meshstor-main), runs each mode, then
restores the prior system meshstor-ms package.

Flags:
  --level=raid1|raid10   raid level (default: raid1)
  --branch=NAME          feature branch to merge atop meshstor-main
                         (default: empty = pure meshstor-main)
  --modes=M1,M2,M3       comma-separated mode labels (default: all 3 in
                         fixed order: kernel-md-internal,ms-internal,ms-lockless)
  --port=N               nvmet-tcp port (default: 7720)
  --cool-thresh-k=N      max sensor temp Kelvin before next mode runs
                         (default: 348 = 75 °C; 0 disables)
  --no-cache             bypass build/cache/

Defaults:
  Suites: same 8 as perf-compare (4 SNIA + 4 kp-*).
  Override via positional args or the SUITES env var.

Output:
  $OUT_BASE/<mode>/results/<suite>/run.log
  View with: $EXTRACT_TABLE $OUT_BASE
EOF
}

# ---- main flow helpers ----

require_root() { [[ $EUID -eq 0 ]] || die "must run as root (try: sudo $0 ...)"; }

require_tools() {
    local missing=()
    for t in dkms modprobe lsmod fio jq awk mdadm; do
        command -v "$t" >/dev/null 2>&1 || missing+=("$t")
    done
    [[ -x "$MDADM_BIN" ]]    || missing+=("mdadm-fork at $MDADM_BIN")
    [[ -x "$REBUILD_MAIN" ]]  || missing+=("$REBUILD_MAIN")
    [[ -x "$BUILD_TARBALL" ]] || missing+=("$BUILD_TARBALL")
    [[ -x "$RUN_PERF" ]]      || missing+=("$RUN_PERF")
    [[ -x "$EXTRACT_TABLE" ]] || missing+=("$EXTRACT_TABLE")
    if (( ${#missing[@]} )); then
        die "missing: ${missing[*]}"
    fi
}

require_partitions() {
    local p
    for p in "${LOCALS[@]}" "${REMOTES[@]}"; do
        [[ -b "$p" ]] || die "$p is not a block device"
    done
}

require_suites() {
    local s
    for s in "${SUITES[@]}"; do
        [[ -d "$s" && -x "$s/run.sh" ]] || die "suite missing or not runnable: $s"
    done
}

setup_msadm_wrapper() {
    cat > "$MSADM_WRAPPER" <<EOF
#!/bin/sh
# autogenerated by perf-bitmap-compare
exec "$MDADM_BIN" --subsys=ms "\$@"
EOF
    chmod +x "$MSADM_WRAPPER"
    log "msadm wrapper: $MSADM_WRAPPER -> $MDADM_BIN --subsys=ms"
}

setup_nvmet_modules() {
    if [[ ! -d /sys/kernel/config/nvmet ]]; then
        log "modprobe nvmet nvmet-tcp"
        modprobe nvmet     || die "modprobe nvmet failed"
        modprobe nvmet-tcp || die "modprobe nvmet-tcp failed"
    fi
}

run_mode() {
    local mode="$1"
    local engine="${MODE_ENGINE[$mode]}"
    local bitmap="${MODE_BITMAP[$mode]}"
    local needs_ms="${MODE_NEEDS_MS[$mode]}"
    local out="$OUT_BASE/$mode"
    local bench_dir="$out/results"
    mkdir -p "$out"

    log "=== mode: $mode (engine=$engine bitmap=$bitmap) ==="

    if (( needs_ms )); then
        if ! load_ms_modules; then
            warn "modprobe ms_mod failed for $mode"
            echo "LOAD_FAILED" > "$out/status"
            return 0
        fi
    else
        unload_ms_modules
    fi

    local -a args
    args=(--engine="$engine" --bitmap="$bitmap" --level="$LEVEL"
          --out-dir="$bench_dir" --port="$PORT")
    if [[ "$engine" == "ms" ]]; then
        args+=(--msadm="$MSADM_WRAPPER")
    fi
    local p
    for p in "${LOCALS[@]}";  do args+=(--local="$p"); done
    for p in "${REMOTES[@]}"; do args+=(--remote="$p"); done

    if "$RUN_PERF" "${args[@]}" "${SUITES[@]}"; then
        echo "OK" > "$out/status"
    else
        echo "BENCH_FAILED" > "$out/status"
    fi
    log "=== $mode done: $(cat "$out/status") ==="
}

main() {
    if [[ $# -eq 0 ]] || [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
        usage; exit 0
    fi

    # ---- arg parse ----
    local _pos=()
    local raw_modes=""
    while (($#)); do
        case "$1" in
            --level=*)         LEVEL="${1#--level=}"; shift ;;
            --local=*)         LOCALS+=("${1#--local=}"); shift ;;
            --remote=*)        REMOTES+=("${1#--remote=}"); shift ;;
            --branch=*)        BRANCH="${1#--branch=}"; shift ;;
            --modes=*)         raw_modes="${1#--modes=}"; shift ;;
            --port=*)          PORT="${1#--port=}"; shift ;;
            --cool-thresh-k=*) COOL_THRESH_K="${1#--cool-thresh-k=}"; shift ;;
            --no-cache)        NO_CACHE=1; shift ;;
            --) shift; _pos+=("$@"); break ;;
            -*) echo "error: unknown flag: $1" >&2; usage >&2; exit 2 ;;
            *)  _pos+=("$1"); shift ;;
        esac
    done

    # Positional vs flag forms (mirrors perf-compare).
    if (( ${#LOCALS[@]} > 0 )) || (( ${#REMOTES[@]} > 0 )); then
        SUITES_POS=("${_pos[@]}")
    else
        if (( ${#_pos[@]} < 2 )); then usage >&2; exit 2; fi
        LOCALS=("${_pos[0]}")
        REMOTES=("${_pos[1]}")
        SUITES_POS=("${_pos[@]:2}")
    fi

    if (( ${#LOCALS[@]} != ${#REMOTES[@]} )); then
        die "--local count (${#LOCALS[@]}) must equal --remote count (${#REMOTES[@]})"
    fi
    case "$LEVEL" in
        raid1)  (( ${#LOCALS[@]} == 1 )) || die "raid1 needs 1 local + 1 remote (got ${#LOCALS[@]} + ${#REMOTES[@]})" ;;
        raid10) (( ${#LOCALS[@]} >= 2 )) || die "raid10 needs at least 2 local + 2 remote" ;;
        *) die "unsupported --level: $LEVEL (raid1 raid10)" ;;
    esac

    # Resolve modes + suites.
    parse_modes "$raw_modes" || exit 2
    derive_variant_ver

    # SUITES: from positional args, or SUITES env, or DEFAULT_SUITES.
    local _names
    if (( ${#SUITES_POS[@]} > 0 )); then
        _names=("${SUITES_POS[@]}")
    else
        # shellcheck disable=SC2206
        _names=( ${SUITES:-${DEFAULT_SUITES[*]}} )
    fi
    SUITES=()
    local s
    for s in "${_names[@]}"; do
        if [[ "$s" == /* ]]; then SUITES+=("$s"); else SUITES+=("$SUITES_BASE/$s"); fi
    done

    # ---- preflight ----
    require_root
    require_tools
    require_partitions
    require_suites
    setup_msadm_wrapper
    setup_nvmet_modules

    mkdir -p "$OUT_BASE"
    cache_sweep_tmp
    if (( NO_CACHE == 0 )); then
        resolve_shas
    fi

    log "bitmap-compare: kernel=$(uname -r) branch=${BRANCH:-(meshstor-main)}"
    log "bitmap-compare: legs local=${LOCALS[*]} remote=${REMOTES[*]} level=$LEVEL"
    log "bitmap-compare: modes=(${SELECTED_MODES[*]}) out=$OUT_BASE"

    # ---- single build/install ----
    remove_existing_pkg
    trap restore_system EXIT

    local rebuild_log="$OUT_BASE/rebuild.log"
    local build_log="$OUT_BASE/build.log"
    local tarball
    if ! tarball="$(obtain_tarball "meshstor" "$OUT_BASE" "$rebuild_log" "$build_log")"; then
        die "build failed (see $OUT_BASE/{rebuild,build}.log)"
    fi
    if ! install_variant "meshstor" "${VARIANT_VER[meshstor]}" "$tarball" >> "$build_log" 2>&1; then
        die "dkms install failed (see $build_log)"
    fi

    # ---- mode loop ----
    local mode
    for mode in "${SELECTED_MODES[@]}"; do
        wait_cool
        run_mode "$mode"
    done

    # ---- view hint ----
    log "view: $EXTRACT_TABLE $OUT_BASE"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
