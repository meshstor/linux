#!/usr/bin/env bash
# perf-make-test-partitions.sh — manage NVMe perf-test partitions.
# Default mode adds two 25 GiB test partitions in the disk's trailing
# free space; --remove tears them down. Idempotent on re-run.
#
# Validations (both modes):
#   - argument is a block device under /dev/nvme*n*
#   - transport is nvme (lsblk -no TRAN)
#   - partition table is GPT (lsblk -no PTTYPE)
#   - physical block size is 4096 — accepts 4Kn AND 512e (rejects 512n)
#
# Create mode also requires:
#   - at least COUNT * SIZE_GIB of contiguous unallocated free space
#
# Created partitions (matched to the CSI driver's goparted member layout so
# the array built on them benchmarks what production deploys):
#   - COUNT × SIZE_GIB (default 2 × 25 GiB; configurable via env)
#   - aligned to a fixed 1 MiB (driver goparted alignBytes) — covers 4 KiB
#     physical blocks on both 4Kn and 512e disks
#   - GPT type Linux RAID (driver gpt.LinuxRAID), and the body is zero-filled
#     (shred -z) so a later --assume-clean array starts from identical mirrors
#   - GPT names: <devbasename>-meshstor-test-1 … <devbasename>-meshstor-test-<COUNT>
#     (e.g. with COUNT=2: nvme0n1-meshstor-test-1, nvme0n1-meshstor-test-2,
#     reachable at /dev/disk/by-partlabel/<devbasename>-meshstor-test-<id>)
#
# Idempotency:
#   - re-running create with matching state is a no-op (exit 0)
#   - re-running create with mismatched state dies, instructs --remove
#   - --remove refuses to act on busy partitions (mounted, swap, mdraid,
#     holders, lsof) and removes nothing if anything is busy
#
# Usage:
#   sudo bin/perf-make-test-partitions /dev/nvme0n1            # create (default)
#   sudo bin/perf-make-test-partitions /dev/nvme0n1 --remove   # remove its test partitions
#
# Flags:
#   -y, --yes      skip the 5-second cancel window
#       --remove   remove existing <base>-meshstor-test-N partitions (no creation)
#   -h, --help     show this help
#
# Env (create mode only):
#   SIZE_GIB=N     size of each partition (default 25)
#   COUNT=N        number of partitions to create (default 2)
set -euo pipefail

die()  { printf 'error: %s\n' "$*" >&2; exit 1; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
log()  { printf '%s\n' "$*"; }

# round_up X Y -> smallest multiple of Y that is >= X (integer math)
round_up() {
    local x="$1" y="$2"
    if (( x == 0 )); then printf '0\n'; return; fi
    printf '%s\n' "$(( ((x + y - 1) / y) * y ))"
}

# compute_align_bytes PHYS OPT -> a fixed 1 MiB, matching the CSI driver's
# goparted alignBytes (a hard-coded 1 MiB). PHYS/OPT are accepted for call-site
# symmetry but deliberately ignored: the 1 MiB floor already covers every 4 KiB
# physical block, and honoring a larger optimal_io_size here would start the
# partition on a boundary the driver never would — defeating the goal of
# benchmarking the driver's exact member layout.
compute_align_bytes() {
    local phys="$1" opt="$2"
    : "$phys" "$opt"  # unused; CSI parity pins alignment to a fixed 1 MiB
    printf '%s\n' "$((1024 * 1024))"
}

# parse_free_region_b: reads `parted -m unit B print free` on stdin,
# writes "START_B END_B SIZE_B" of the largest free region to stdout.
# Exits non-zero (with no output) when no free region exists.
parse_free_region_b() {
    awk -F: '
        /:free;$/ {
            # Strip trailing "B" from start/end fields.
            s = $2; sub(/B$/, "", s)
            e = $3; sub(/B$/, "", e)
            sz = e - s
            if (sz > max) { max = sz; mstart = s; mend = e }
        }
        END {
            if (max == 0) exit 1
            printf "%s %s %s\n", mstart, mend, max
        }
    '
}

# match_test_label BASE LABEL -> 0 if LABEL matches "<BASE>-meshstor-test-<digits>"
match_test_label() {
    local base="$1" label="$2"
    [[ "$label" =~ ^${base}-meshstor-test-[0-9]+$ ]]
}

# scan_test_partitions DEV BASE -> writes "NUM NAME LABEL SIZE" lines to
# stdout for each partition on DEV whose PARTLABEL matches the test
# pattern. Numbers are partition numbers (column from lsblk PARTN).
scan_test_partitions() {
    local dev="$1" base="$2"
    lsblk -ln -o NAME,PARTN,PARTLABEL,SIZE "$dev" 2>/dev/null \
        | awk -v base="$base" '
            $3 ~ ("^" base "-meshstor-test-[0-9]+$") {
                printf "%s %s %s %s\n", $2, $1, $3, $4
            }
        '
}

# wait_partition_node DEV LABEL -> echo the /dev node whose PARTLABEL matches
# LABEL, polling up to ~10s; non-zero on timeout. partprobe + `udevadm settle`
# can return before udev has populated the partition's PARTLABEL: the kernel
# emits the partition add-uevents slightly after partprobe returns, so a settle
# fired immediately drains an empty queue and exits before the events arrive,
# leaving a single post-settle lsblk read racy. Poll the way the CSI driver
# does (goparted ensurePartitionVisible) rather than trusting one read.
wait_partition_node() {
    local dev="$1" label="$2" i=0 node
    while (( i < 100 )); do
        node="$(lsblk -ln -o NAME,PARTLABEL "$dev" 2>/dev/null \
            | awk -v lbl="$label" '$2==lbl {print "/dev/"$1; exit}')"
        if [[ -n "$node" && -b "$node" ]]; then
            printf '%s\n' "$node"
            return 0
        fi
        sleep 0.1
        udevadm settle >/dev/null 2>&1 || true
        (( i++ ))
    done
    return 1
}

# remove_mode DEV BASE YES -> validate, list, refuse-if-busy, delete.
remove_mode() {
    local dev="$1" base="$2" yes="$3"
    local entries blockers=()

    # Snapshot the test partitions.
    mapfile -t entries < <(scan_test_partitions "$dev" "$base")
    if [[ ${#entries[@]} -eq 0 ]]; then
        log "nothing to remove on $dev (no ${base}-meshstor-test-N partitions)"
        return 0
    fi

    # Refuse if any candidate is busy. Collect ALL hits before failing.
    local mountinfo swaps mdstat
    mountinfo="$(cat /proc/self/mountinfo 2>/dev/null || true)"
    swaps="$(cat /proc/swaps 2>/dev/null || true)"
    mdstat="$(cat /proc/mdstat 2>/dev/null || true)"

    local entry num name label size pdev holders_dir
    for entry in "${entries[@]}"; do
        read -r num name label size <<<"$entry"
        pdev="/dev/$name"
        if grep -qE "[[:space:]]${pdev}[[:space:]]" <<<"$mountinfo"; then
            blockers+=("$pdev ($label): mounted")
        fi
        if grep -qE "^${pdev}[[:space:]]" <<<"$swaps"; then
            blockers+=("$pdev ($label): active swap")
        fi
        if grep -q "${name}\b" <<<"$mdstat"; then
            blockers+=("$pdev ($label): in /proc/mdstat")
        fi
        holders_dir="/sys/class/block/${name}/holders"
        # shellcheck disable=SC2012  # sysfs entries are simple names; ls is fine
        if [[ -d "$holders_dir" ]] && [[ -n "$(ls -A "$holders_dir" 2>/dev/null)" ]]; then
            # shellcheck disable=SC2012
            blockers+=("$pdev ($label): has holders ($(ls -A "$holders_dir" | tr '\n' ' '))")
        fi
        if command -v lsof >/dev/null 2>&1; then
            if lsof -- "$pdev" >/dev/null 2>&1; then
                blockers+=("$pdev ($label): open file handles (lsof)")
            fi
        fi
    done

    if [[ ${#blockers[@]} -gt 0 ]]; then
        printf 'error: refusing to remove — %d busy partition(s):\n' "${#blockers[@]}" >&2
        printf '  %s\n' "${blockers[@]}" >&2
        exit 1
    fi

    # Print plan.
    log "Plan: remove ${#entries[@]} test partition(s) from $dev:"
    for entry in "${entries[@]}"; do
        read -r num name label size <<<"$entry"
        log "  /dev/$name  $label  $size"
    done

    if [[ "$yes" -eq 0 ]]; then
        printf 'Proceeding in 5 s — Ctrl-C to cancel'
        for _ in 1 2 3 4 5; do printf '.'; sleep 1; done
        printf '\n'
    fi

    # Remove in DESCENDING partition-number order.
    local nums=()
    for entry in "${entries[@]}"; do
        read -r num _ _ _ <<<"$entry"
        nums+=("$num")
    done
    # Sort numerically descending.
    IFS=$'\n' read -r -d '' -a nums_sorted < <(printf '%s\n' "${nums[@]}" | sort -rn && printf '\0')
    for num in "${nums_sorted[@]}"; do
        parted -s "$dev" rm "$num"
    done

    partprobe "$dev" 2>/dev/null || true
    udevadm settle

    # Verify nothing matching remains.
    mapfile -t entries < <(scan_test_partitions "$dev" "$base")
    if [[ ${#entries[@]} -ne 0 ]]; then
        die "post-remove: still found matching partitions: ${entries[*]}"
    fi
    log "removed ${#nums_sorted[@]} test partition(s) from $dev"
}

main() {
    SIZE_GIB="${SIZE_GIB:-25}"
    COUNT="${COUNT:-2}"

    REMOVE=0
    YES=0
    DEV=""
    for arg in "$@"; do
        case "$arg" in
            --remove)  REMOVE=1 ;;
            -y|--yes)  YES=1 ;;
            -h|--help)
                sed -n '2,42p' "$0" | sed 's/^# \?//'
                exit 0
                ;;
            -*) die "unknown flag: $arg" ;;
            *)  [[ -z "$DEV" ]] || die "extra positional arg: $arg"
                DEV="$arg" ;;
        esac
    done
    [[ -n "$DEV" ]] || die "usage: $0 /dev/nvmeXnY [--remove] [-y|--yes]"

    # ---- root check ----
    [[ $EUID -eq 0 ]] || die "must run as root (try: sudo $0 $*)"

    # ---- tool check ----
    for t in lsblk blockdev parted partprobe udevadm awk shred; do
        command -v "$t" >/dev/null 2>&1 || die "missing tool: $t"
    done

    # ---- device validation ----
    [[ -b "$DEV" ]] || die "not a block device: $DEV"
    # _TEST_ALLOW_NON_NVME=1 bypasses the NVMe path/TRAN gates (integration tests).
    # Not documented in --help; intentionally hidden.
    if [[ "${_TEST_ALLOW_NON_NVME:-0}" != "1" ]]; then
        [[ "$DEV" =~ ^/dev/nvme[0-9]+n[0-9]+$ ]] || die "device name doesn't look like a whole-NVMe disk: $DEV (expected /dev/nvmeXnY)"
        TRAN="$(lsblk -dno TRAN "$DEV" 2>/dev/null || echo)"
        [[ "$TRAN" == "nvme" ]] || die "not an NVMe device (lsblk TRAN=$TRAN)"
    else
        TRAN="(test)"
    fi

    PTTYPE="$(lsblk -dno PTTYPE "$DEV" 2>/dev/null || echo)"
    if [[ -z "$PTTYPE" ]]; then
        die "$DEV has no partition table (PTTYPE='')
to initialize an empty disk, run:
    sudo parted -s $DEV mklabel gpt
then re-run this script."
    elif [[ "$PTTYPE" != "gpt" ]]; then
        die "$DEV has a non-GPT partition table (PTTYPE='$PTTYPE')
this script refuses to convert non-GPT labels — running 'mklabel gpt' on
this disk would destroy any existing partition data. If the disk is
genuinely unused, wipe it first:
    sudo wipefs -a $DEV
    sudo parted -s $DEV mklabel gpt
then re-run this script."
    fi

    LOG_SEC="$(blockdev --getss "$DEV")"        # 512 on 512e, 4096 on 4Kn
    PHY_SEC="$(blockdev --getpbsz "$DEV")"      # 4096 on both 4Kn and 512e
    OPT_IO="$(cat "/sys/class/block/$(basename "$DEV")/queue/optimal_io_size" 2>/dev/null || echo 0)"

    DEV_NAME="$(basename "$DEV")"

    if [[ $REMOVE -eq 1 ]]; then
        if [[ -n "${SIZE_GIB+x}" ]] && [[ "$SIZE_GIB" != "25" ]]; then
            log "(SIZE_GIB ignored in --remove mode)"
        fi
        if [[ -n "${COUNT+x}" ]] && [[ "$COUNT" != "2" ]]; then
            log "(COUNT ignored in --remove mode)"
        fi
        remove_mode "$DEV" "$DEV_NAME" "$YES"
        exit 0
    fi

    # Idempotency: if test partitions already exist, decide what to do.
    mapfile -t existing < <(scan_test_partitions "$DEV" "$DEV_NAME")
    if [[ ${#existing[@]} -gt 0 ]]; then
        expected_size_h="${SIZE_GIB}G"
        all_match=1
        if [[ ${#existing[@]} -ne $COUNT ]]; then all_match=0; fi
        for entry in "${existing[@]}"; do
            read -r _ _ _ size <<<"$entry"
            [[ "$size" == "$expected_size_h" ]] || all_match=0
        done
        if [[ $all_match -eq 1 ]]; then
            log "$COUNT test partition(s) of size ${SIZE_GIB}G already present on $DEV — nothing to do"
            exit 0
        fi
        {
            printf 'error: partial / mismatched test partitions exist on %s:\n' "$DEV"
            for entry in "${existing[@]}"; do
                read -r _ name label size <<<"$entry"
                printf '  /dev/%s  %s  %s\n' "$name" "$label" "$size"
            done
            printf 're-run with: sudo %s %s --remove\n' "$0" "$DEV"
            printf 'then re-run this script.\n'
        } >&2
        exit 1
    fi

    # ---- free space discovery (exact bytes) ----
    read -r FREE_START_B FREE_END_B FREE_SIZE_B < <(
        parted -s -m "$DEV" unit B print free 2>/dev/null | parse_free_region_b
    ) || die "no free region found on $DEV"

    # ---- compute alignment ----
    ALIGN_B="$(compute_align_bytes "$PHY_SEC" "$OPT_IO")"
    GIB=$((1024 * 1024 * 1024))
    SIZE_B=$((SIZE_GIB * GIB))

    [[ "$COUNT" =~ ^[1-9][0-9]*$ ]] \
        || die "COUNT must be a positive integer (got: '$COUNT')"
    # Each partition begins where the previous one ends, so per-partition
    # alignment requires SIZE_B to be a whole multiple of ALIGN_B. With the
    # 1 MiB floor this holds for any sane SIZE_GIB; fail loudly otherwise.
    (( SIZE_B % ALIGN_B == 0 )) \
        || die "SIZE_GIB=${SIZE_GIB} is not a multiple of alignment ${ALIGN_B} B"

    # Per-partition byte ranges and labels (1-based indexing).
    declare -a P_START_B P_END_B LABELS
    P_START_B[1]="$(round_up "$FREE_START_B" "$ALIGN_B")"
    P_END_B[1]=$(( P_START_B[1] + SIZE_B ))
    LABELS[1]="${DEV_NAME}-meshstor-test-1"
    for (( i = 2; i <= COUNT; i++ )); do
        P_START_B[i]=${P_END_B[i-1]}
        P_END_B[i]=$(( P_START_B[i] + SIZE_B ))
        LABELS[i]="${DEV_NAME}-meshstor-test-${i}"
    done

    (( P_END_B[COUNT] <= FREE_END_B )) \
        || die "would overflow free region: need ${SIZE_GIB}GiB × ${COUNT} = $((SIZE_B*COUNT)) B aligned to ${ALIGN_B} B starting at ${P_START_B[1]} B; free region ends at ${FREE_END_B} B"

    # ---- print plan ----
    cat <<EOF
Device:        $DEV
  transport:   $TRAN
  pt type:     $PTTYPE
  logical sec: $LOG_SEC B
  physical:    $PHY_SEC B
  optimal io:  $OPT_IO B
  free region: ${FREE_START_B}–${FREE_END_B} B  ($((FREE_SIZE_B / GIB)) GiB)
  align:       ${ALIGN_B} B

Plan: create $COUNT partition(s), $SIZE_GIB GiB each, ${ALIGN_B}-byte aligned:
EOF
    for (( i = 1; i <= COUNT; i++ )); do
        printf '  %s: %s → %s B  (%s GiB)\n' \
            "${LABELS[i]}" "${P_START_B[i]}" "${P_END_B[i]}" "$SIZE_GIB"
    done

    if [[ $YES -eq 0 ]]; then
        printf 'Proceeding in 5 s — Ctrl-C to cancel'
        for _ in 1 2 3 4 5; do printf '.'; sleep 1; done
        printf '\n'
    fi

    # ---- create partitions ----
    # parted's `B` end is inclusive — subtract 1 byte from the exclusive end.
    local -a parted_args=( -s "$DEV" )
    for (( i = 1; i <= COUNT; i++ )); do
        parted_args+=( mkpart "${LABELS[i]}" ext4 \
            "${P_START_B[i]}B" "$(( P_END_B[i] - 1 ))B" )
    done
    parted "${parted_args[@]}"

    # Re-read the partition table.
    partprobe "$DEV"
    udevadm settle

    # ---- post-create verification ----
    echo
    echo "Verification — new layout:"
    parted -s "$DEV" unit MiB print | tail -n +2

    # Discover the new device nodes by PARTLABEL and verify each starts on
    # an ALIGN_B byte boundary. Kernel always reports /sys/.../start in
    # 512 B sectors regardless of LBA size.
    declare -a PART_DEVS
    for (( i = 1; i <= COUNT; i++ )); do
        pdev="$(wait_partition_node "$DEV" "${LABELS[i]}")" \
            || die "post-create: could not locate /dev node for ${LABELS[i]}"
        start_sectors="$(cat "/sys/class/block/$(basename "$pdev")/start" 2>/dev/null)"
        start_bytes=$(( start_sectors * 512 ))
        if (( start_bytes % ALIGN_B != 0 )); then
            die "post-create: $pdev start offset $start_bytes B is NOT a multiple of ${ALIGN_B} B (alignment broken)"
        fi
        PART_DEVS[i]="$pdev"
    done

    # ---- match the CSI driver's member identity + zeroing ----
    # The driver creates each member with GPT type Linux RAID (goparted
    # gpt.LinuxRAID) and zero-fills the body (shred -z) before building the
    # array with --assume-clean, so its mirrors start byte-identical. parted's
    # `ext4` fs-type above left a generic Linux-data type and an un-zeroed
    # body; reproduce both so the array benchmarked here matches production.
    #
    # Data-safety gate: a partition block device always exposes
    # /sys/.../partition (its number); a whole-disk node never does. Resolving
    # the partition number through that file is what keeps the type-flip and the
    # destructive shred below off a whole-disk node, regardless of transport or
    # LBA size.
    declare -a PART_NUMS
    for (( i = 1; i <= COUNT; i++ )); do
        pbase="$(basename "${PART_DEVS[i]}")"
        [[ -f "/sys/class/block/$pbase/partition" ]] \
            || die "refusing to modify non-partition node: ${PART_DEVS[i]}"
        PART_NUMS[i]="$(cat "/sys/class/block/$pbase/partition")"
    done

    # GPT type -> Linux RAID. parted's `raid` flag sets the type GUID to
    # A19D880F-… (the driver's gpt.LinuxRAID). Re-read the table once after.
    for (( i = 1; i <= COUNT; i++ )); do
        parted -s "$DEV" set "${PART_NUMS[i]}" raid on
    done
    partprobe "$DEV"
    udevadm settle

    # Zero each member body, exactly as the driver does, so a later
    # --assume-clean array starts from identical mirrors. Operates only on the
    # partition nodes gated above — never $DEV.
    for (( i = 1; i <= COUNT; i++ )); do
        pdev="${PART_DEVS[i]}"
        [[ -b "$pdev" ]] || die "post-create: $pdev vanished before zeroing"
        log "zeroing $pdev (shred -z) to match driver --assume-clean"
        shred -f -n 1 -z "$pdev"
    done

    echo
    echo "Created:"
    for (( i = 1; i <= COUNT; i++ )); do
        echo "  ${PART_DEVS[i]}  (${LABELS[i]})"
    done
}

# Library mode guard: when sourced (e.g., by tests), expose helpers but do
# not run main. When executed directly, run main with the script's argv.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
