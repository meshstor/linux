#!/bin/sh
# prerm for meshstor-nvme-rdma-dkms
set -e

NAME=meshstor-nvme-rdma
VERSION="#MODULE_VERSION#"

case "$1" in
    remove|upgrade|deconfigure)
        if command -v dkms >/dev/null 2>&1; then
            dkms remove -m "$NAME" -v "$VERSION" --all || :
        fi
        ;;
esac

#DEBHELPER#

exit 0
