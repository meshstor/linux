PACKAGE_NAME="meshstor-ms"
PACKAGE_VERSION="@VERSION@"

MAKE[0]="make -j$(nproc) KDIR=/lib/modules/${kernelver}/build"

# ms-llbitmap is built into the ms_mod composite (matches the in-tree pattern
# where llbitmap is part of md_mod), so we do not list it as a separate module.
BUILT_MODULE_NAME[0]="ms_mod"
BUILT_MODULE_NAME[1]="raid1_ms"
BUILT_MODULE_NAME[2]="raid10_ms"

DEST_MODULE_LOCATION[0]="/extra"
DEST_MODULE_LOCATION[1]="/extra"
DEST_MODULE_LOCATION[2]="/extra"

AUTOINSTALL="yes"
