# meshstor-ms-dkms.spec — DKMS package for the parallel ms_* subsystem
#
# Builds a noarch .rpm that drops the source tree into
# /usr/src/meshstor-ms-@MODULE_VERSION@/ and registers it with DKMS. DKMS
# handles per-kernel compilation on install and on every kernel update via
# its dkms_autoinstaller / kmods systemd integration on RHEL/Rocky/Alma.
#
# Version          — RPM Version: tag (forbids '-', so '-' → '~' in build-rpm.sh).
# module_version   — original upstream/DKMS version with '-' preserved;
#                    matches the tarball filename, the unpacked directory,
#                    and the DKMS module version used by `dkms add -v`.

%global pkgname         meshstor-ms
%global modname         meshstor-ms
%global module_version  @MODULE_VERSION@

Name:           %{pkgname}-dkms
Version:        @VERSION@
Release:        1%{?dist}
Summary:        meshstor parallel md-style raid subsystem (ms_mod, raid1_ms, raid10_ms)

License:        GPL-2.0-or-later
URL:            https://example.com/meshstor-ms
Source0:        %{pkgname}-%{module_version}.dkms.tar.gz

BuildArch:      noarch
Requires:       dkms >= 2.8.0
Requires:       kernel-devel
Requires(post):   dkms
Requires(preun):  dkms
Requires(postun): dkms

%description
The meshstor-ms package provides a parallel md-style RAID subsystem that
coexists with the kernel's built-in md driver under separate /dev names
(/dev/ms*), /proc files (/proc/msstat), and sysfs paths
(/sys/block/ms*/ms/). It carries selected upstream md performance work
including the lockless bitmap (llbitmap), per-rdev latency-aware read
balancing (EWMA), per-bucket barrier arrays for raid10, and zero-copy
raid1->raid10 takeover.

The on-disk superblock format is identical to the kernel md format —
arrays can be moved between subsystems by re-attaching the disks under
the alternate driver. Userspace tooling for ms is customer-supplied
(ms-aware mdadm fork; not bundled).

%prep
%setup -q -n %{pkgname}-%{module_version}

%build
# DKMS handles compilation per-kernel; nothing to do at package-build time.

%install
mkdir -p %{buildroot}/usr/src/%{pkgname}-%{module_version}
cp -a . %{buildroot}/usr/src/%{pkgname}-%{module_version}/
# DKMS picks up the package via /usr/src/<name>-<version>/dkms.conf

%post
dkms add -m %{pkgname} -v %{module_version} || :
dkms build -m %{pkgname} -v %{module_version} || :
dkms install -m %{pkgname} -v %{module_version} || :

%preun
# Remove DKMS registration before package files are removed.
if [ "$1" = "0" ]; then
    # Pre-emptively prune cross-kernel weak-updates symlinks for our three
    # modules across every installed kernel, BEFORE calling `dkms remove`.
    # Rationale: DKMS's framework default `post_transaction` runs
    # `dracut --regenerate-all --force` at the end of `dkms remove`. If a
    # newer kernel has weak-updates/ symlinks pointing into the kernel
    # whose extra/ payload `dkms remove` just deleted, those links become
    # dangling between the file delete and the dracut step, and dracut
    # fails on that kernel with "installkernel failed in module
    # kernel-modules-extra". Removing the symlinks up front avoids the
    # window. We use -type l (not -xtype l like %posttrans) because the
    # links are still live at this point — they only become dangling
    # moments later, inside `dkms remove`. The package is being erased,
    # so any reference to our modules is going away regardless.
    for kdir in "${MESHSTOR_MOD_ROOT:-/usr/lib/modules}"/*/weak-updates; do
        [ -d "$kdir" ] || continue
        for name in ms_mod raid1_ms raid10_ms; do
            find "$kdir" -maxdepth 2 -name "${name}.ko*" -type l -delete
        done
    done 2>/dev/null || :

    dkms remove -m %{pkgname} -v %{module_version} --all || :
fi

%postun
# DKMS rebuild on kernel updates is handled automatically; nothing to do here.

%posttrans
# Self-heal dangling weak-updates symlinks for the three modules this
# package owns. RHEL's weak-modules mechanism can leave broken symlinks
# under /usr/lib/modules/<other-kver>/weak-updates/ pointing into a
# kernel whose extra/ payload has been removed; dracut then fails with
# "installkernel failed in module kernel-modules-extra" when it walks
# those broken symlinks. We delete only links matching our three module
# names that have no resolvable target (-xtype l). Live links (target
# exists) and broken links owned by other DKMS packages are untouched.
for kdir in "${MESHSTOR_MOD_ROOT:-/usr/lib/modules}"/*/weak-updates; do
    [ -d "$kdir" ] || continue
    for name in ms_mod raid1_ms raid10_ms; do
        find "$kdir" -maxdepth 2 -name "${name}.ko*" -xtype l -delete
    done
done 2>/dev/null || :

%triggerin -- kernel-core, kernel
# After a new kernel is installed, weak-modules may have created links
# under that kernel's weak-updates/ that are already broken (target
# kernel's extra/ payload was removed in the same transaction). Prune
# them. See the same comment block in %posttrans for full rationale.
for kdir in "${MESHSTOR_MOD_ROOT:-/usr/lib/modules}"/*/weak-updates; do
    [ -d "$kdir" ] || continue
    for name in ms_mod raid1_ms raid10_ms; do
        find "$kdir" -maxdepth 2 -name "${name}.ko*" -xtype l -delete
    done
done 2>/dev/null || :

%triggerun -- kernel-core, kernel
# A kernel is being removed. Symlinks in *other* kernels' weak-updates/
# that pointed into the kernel being removed are about to become
# dangling. Prune them across all kernels' weak-updates/ trees.
for kdir in "${MESHSTOR_MOD_ROOT:-/usr/lib/modules}"/*/weak-updates; do
    [ -d "$kdir" ] || continue
    for name in ms_mod raid1_ms raid10_ms; do
        find "$kdir" -maxdepth 2 -name "${name}.ko*" -xtype l -delete
    done
done 2>/dev/null || :

%files
%license COPYING
/usr/src/%{pkgname}-%{module_version}/

%changelog
* @CHANGELOG_DATE@ Meshstor <support@example.com> - @VERSION@-1
- Initial DKMS package release of the parallel ms_* subsystem.
- Modules: ms_mod, raid1_ms, raid10_ms (ms-llbitmap built into ms_mod).
- Targets: RHEL 9.x / Rocky 9 / Alma 9 (kernel 5.14-era backported),
  RHEL 10.x / Rocky 10 / Alma 10 (kernel 6.12),
  Ubuntu 24.04 LTS HWE (kernel 6.14+),
  Ubuntu 26.04 LTS (kernel 6.17+).
