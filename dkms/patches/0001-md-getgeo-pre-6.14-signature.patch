Backport: md_getgeo callback signature pre-6.14

In kernel 6.14 the block_device_operations.getgeo callback was changed
from taking (struct block_device *) to (struct gendisk *). Our integrated
md.c uses the new signature.

For older kernels, provide a wrapper that adapts the old signature to
the new one, and conditionally assign it in the md_fops table.

--- a/md.c
+++ b/md.c
@@ -8593,6 +8593,15 @@ static int md_getgeo(struct gendisk *disk, struct hd_geometry *geo)
 	return 0;
 }

+#if LINUX_VERSION_CODE < KERNEL_VERSION(6, 14, 0)
+/* Pre-6.14, block_device_operations.getgeo took (struct block_device *).
+ * Wrap our gendisk-taking md_getgeo to match. */
+static int md_getgeo_compat(struct block_device *bdev, struct hd_geometry *geo)
+{
+	return md_getgeo(bdev->bd_disk, geo);
+}
+#endif
+
 static int md_ioctl(struct block_device *bdev, blk_mode_t mode,
 			unsigned int cmd, unsigned long arg)
 {
@@ -8612,7 +8621,11 @@ static const struct block_device_operations md_fops =
 	.ioctl		= md_ioctl,
 	.compat_ioctl	= md_compat_ioctl,
 #endif
+#if LINUX_VERSION_CODE < KERNEL_VERSION(6, 14, 0)
+	.getgeo		= md_getgeo_compat,
+#else
 	.getgeo		= md_getgeo,
+#endif
 	.check_events	= md_check_events,
 	.set_read_only	= md_set_read_only,
 };
