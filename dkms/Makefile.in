# meshstor-ms DKMS out-of-tree wrapper Makefile (post-rename layout).
# Source files are ms_*.c / raid*_ms.c after dkms/scripts/build-tarball.sh
# ran the rename pass.

KDIR ?= /lib/modules/$(shell uname -r)/build

obj-m := ms_mod.o raid1_ms.o raid10_ms.o

# md-llbitmap.c is built into the ms_mod composite (matches the in-tree pattern
# where llbitmap is part of md_mod, not a separate .ko). md-autodetect.c is
# excluded — it uses kernel init-only symbols (early_lookup_bdev, init_stat)
# that aren't exported to modules, and our parallel ms subsystem doesn't need
# boot-time autodetect (arrays are created post-boot via userspace tooling).
ms_mod-y     := ms.o ms-bitmap.o ms-llbitmap.o

# raid1_ms.ko = raid1_ms.o (single-object), raid10_ms.ko = raid10_ms.o.
# raid1-10_ms.c is shared source #included by raid1_ms.c and raid10_ms.c.

ccflags-y += -I$(M)/compat
ccflags-y += -include $(M)/compat/compat.h
ccflags-y += -DCONFIG_MD_RAID1=1
ccflags-y += -DCONFIG_MD_RAID10=1
ccflags-y += -DCONFIG_MD_BITMAP=1
ccflags-y += -DCONFIG_MD_LLBITMAP=1

# The block below only applies when this Makefile is invoked directly
# (DKMS or `make` from the source tree). When kbuild re-enters this same
# Makefile via `M=...` to extract obj-m, KBUILD_EXTMOD is set; in that
# context we must not redefine `all` or kbuild's own targets.
#
# We can't use the conventional KERNELRELEASE guard because DKMS sets
# KERNELRELEASE=... on the command line of the OUTER make invocation, so
# KERNELRELEASE alone can't distinguish "DKMS called me" from "kbuild
# recursed into me". KBUILD_EXTMOD is only set by kbuild itself during
# the `make -C $KDIR M=$M` recursion.
ifeq ($(KBUILD_EXTMOD),)

.PHONY: all feature_flags clean modules_install

all: feature_flags
	$(MAKE) -C $(KDIR) M=$(CURDIR) modules

# Feature-detect the target kernel's headers at module-build time. DKMS
# invokes this Makefile with KDIR pointing at the running customer kernel's
# build tree, so feature_flags.h is regenerated fresh on every build to
# match the actual kernel being built against — NOT the kernel that
# produced the .deb/.rpm package.
feature_flags:
	@echo "Auto-detecting kernel features against $(KDIR)..."
	@{ \
	    echo '/* SPDX-License-Identifier: GPL-2.0-or-later */'; \
	    echo '/* Auto-generated by dkms/Makefile.in at module-build time. */'; \
	    echo '/* Target kernel headers: $(KDIR) */'; \
	    echo '#ifndef MESHSTOR_MS_FEATURE_FLAGS_H'; \
	    echo '#define MESHSTOR_MS_FEATURE_FLAGS_H'; \
	    echo ''; \
	    for sym_hdr in \
	        bio_submit_split_bioset:linux/bio.h \
	        bio_submit_split_bioset:linux/blkdev.h \
	        bio_init_inline:linux/bio.h \
	        bdev_rot:linux/blkdev.h \
	        bdev_count_inflight:linux/blkdev.h \
	        bdev_count_inflight:linux/part_stat.h \
	        bdev_write_zeroes_unmap_sectors:linux/blkdev.h \
	        max_hw_wzeroes_unmap_sectors:linux/blkdev.h \
	        timer_container_of:linux/timer.h \
	        kzalloc_obj:linux/slab.h \
	        kmalloc_obj:linux/slab.h \
	        kzalloc_objs:linux/slab.h \
	        kmalloc_objs:linux/slab.h \
	        kvzalloc_objs:linux/slab.h \
	        kmalloc_flex:linux/slab.h \
	        kzalloc_flex:linux/slab.h \
	        register_sysctl_sz:linux/sysctl.h \
	        queue_limits_set:linux/blkdev.h \
	        queue_limits_start_update:linux/blkdev.h \
	        queue_limits_commit_update:linux/blkdev.h \
	        queue_limits_cancel_update:linux/blkdev.h \
	        queue_limits_stack_bdev:linux/blkdev.h \
	        queue_limits_stack_integrity_bdev:linux/blk-integrity.h \
	        queue_limits_stack_integrity_bdev:linux/blkdev.h \
	        bdev_file_open_by_dev:linux/blkdev.h \
	        bdev_file_open_by_dev:linux/fs.h ; do \
	            sym=$${sym_hdr%%:*}; hdr=$${sym_hdr#*:}; \
	            if [ -f "$(KDIR)/include/$$hdr" ] && \
	               grep -qE "\\b$$sym\\b" "$(KDIR)/include/$$hdr"; then \
	                upper=$$(echo "$$sym" | tr 'a-z' 'A-Z'); \
	                if [ "$$sym" = register_sysctl_sz ]; then \
	                    echo "#define HAVE_SYSCTL_REGISTER_TABLE_NO_SENTINEL 1"; \
	                else \
	                    echo "#define HAVE_$$upper 1"; \
	                fi; \
	            fi; \
	    done | sort -u; \
	    if grep -qE "^\\s*#\\s*define\\s+WQ_PERCPU\\b" \
	        "$(KDIR)/include/linux/workqueue.h" 2>/dev/null; then \
	        echo "#define HAVE_WQ_PERCPU 1"; \
	    fi; \
	    if grep -qE "int \\(\\*getgeo\\)\\(struct gendisk" \
	        "$(KDIR)/include/linux/blkdev.h" 2>/dev/null; then \
	        echo "#define HAVE_GETGEO_GENDISK 1"; \
	    fi; \
	    if awk 'BEGIN{RS=";"} /badblocks_check.*sector_t \*bad_sectors/' \
	        "$(KDIR)/include/linux/badblocks.h" 2>/dev/null | grep -q .; then \
	        echo "#define HAVE_BADBLOCKS_CHECK_SECTOR_T_OUTPUTS 1"; \
	    fi; \
	    if grep -qE "alloc_page_buffers\\(struct page \\*page, unsigned long size\\)" \
	        "$(KDIR)/include/linux/buffer_head.h" 2>/dev/null; then \
	        echo "#define HAVE_ALLOC_PAGE_BUFFERS_2ARG 1"; \
	    fi; \
	    if grep -qE "define[[:space:]]+blk_alloc_disk\\([^)]*[lL]im[^)]*node" \
	        "$(KDIR)/include/linux/blkdev.h" 2>/dev/null; then \
	        echo "#define HAVE_BLK_ALLOC_DISK_LIM 1"; \
	    fi; \
	    if awk '/^struct[[:space:]]+queue_limits[[:space:]]*\{/{in_s=1; next} in_s && /^\};/{in_s=0; exit} in_s && /\<features\>/{print "found"; exit}' \
	        "$(KDIR)/include/linux/blkdev.h" 2>/dev/null | grep -q found; then \
	        echo "#define HAVE_QUEUE_LIMITS_FEATURES 1"; \
	    fi; \
	    if awk '/^struct[[:space:]]+mdp_superblock_1[[:space:]]*\{/{in_s=1; next} in_s && /^\};/{in_s=0; exit} in_s && /\<logical_block_size\>[[:space:]]*;/{print "found"; exit}' \
	        "$(KDIR)/include/uapi/linux/raid/md_p.h" 2>/dev/null | grep -q found; then \
	        echo "#define HAVE_MDP_SB1_LOGICAL_BLOCK_SIZE 1"; \
	    fi; \
	    if grep -qE "\\bBLK_STS_INVAL\\b" \
	        "$(KDIR)/include/linux/blk_types.h" 2>/dev/null; then \
	        echo "#define HAVE_BLK_STS_INVAL 1"; \
	    fi; \
	    echo ''; \
	    echo '#endif /* MESHSTOR_MS_FEATURE_FLAGS_H */'; \
	} > compat/feature_flags.h
	@echo "Detected:"
	@grep "^#define HAVE" compat/feature_flags.h | sed 's/^/  /' || echo "  (none — kernel matches in-tree API)"

clean:
	$(MAKE) -C $(KDIR) M=$(CURDIR) clean
	@rm -f compat/feature_flags.h

modules_install:
	$(MAKE) -C $(KDIR) M=$(CURDIR) modules_install

endif
